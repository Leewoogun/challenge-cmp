<?xml version="1.0" encoding="utf-8"?>
<!--
  로컬 개발 서버 평문(HTTP) 통신을 허용하기 위한 화이트리스트.

  - 10.0.2.2  : Android 에뮬레이터에서 호스트 머신(localhost) 으로 매핑되는 특수 주소
  - localhost : iOS/데스크톱 시뮬레이터 또는 같은 기기에서 띄운 서버

  운영 서버(예: api.example.com) 는 명시하지 않았으므로 기본 정책(HTTPS only) 그대로 적용된다.
  release 빌드에 영향 없음.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
